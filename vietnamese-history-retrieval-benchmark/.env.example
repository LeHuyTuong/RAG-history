# Optional local paths/caches. Scripts also work with defaults.
HF_HOME=.cache/huggingface
TRANSFORMERS_CACHE=.cache/huggingface/transformers

# Optional OCR override for pytesseract users.
# TESSERACT_CMD=/usr/local/bin/tesseract

# Optional: set to 1 only if you intentionally want PaddleOCR GPU usage.
PADDLEOCR_USE_GPU=0
